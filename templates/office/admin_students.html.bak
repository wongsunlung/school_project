{% extends 'base.html' %}

{% block title %}Student Administration{% endblock %}

{% block content %}
<div class="container-fluid px-0">
    
    <!-- Top Header Section -->
    <div class="mb-4 pb-2 border-bottom">
        <h2 class="fw-bold text-dark mb-1">Student Academic Records</h2>
        <p class="text-muted mb-0">Approve new student online registration requests, filter profiles, and verify admission eligibility.</p>
    </div>

    <!-- Django Message Notifications -->
    {% if messages %}
        {% for message in messages %}
            <div class="alert alert-{% if message.tags == 'error' %}danger{% else %}success{% endif %} alert-dismissible fade show shadow-sm mb-4" role="alert">
                <i class="fas {% if message.tags == 'error' %}fa-exclamation-circle{% else %}fa-check-circle{% endif %} me-2"></i>{{ message }}
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        {% endfor %}
    {% endif %}

    <!-- Plan B Composite Search Filter -->
    <div class="card card-custom bg-white border-0 shadow-sm p-3 mb-4">
        <form action="{% url 'office:admin_students' %}" method="GET" class="row g-2 align-items-center">
            <div class="col-12 col-md-9">
                <div class="input-group">
                    <span class="input-group-text bg-light text-secondary border-end-0"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control border-start-0 py-2" name="keywords" value="{{ request.GET.keywords }}" placeholder="Search by Student ID, First Name, Last Name, or Email Address (Fuzzy Filter)...">
                </div>
            </div>
            <div class="col-12 col-md-3 d-grid">
                <button type="submit" class="btn btn-primary fw-semibold py-2" style="background-color: #1e3a8a; border: none;">
                    <i class="fas fa-filter me-2"></i>Apply Filter
                </button>
            </div>
        </form>
    </div>

    <!-- Data Table Card -->
    <div class="card card-custom bg-white border-0 shadow-sm p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th>Student ID</th>
                        <th>Full Name</th>
                        <th>Email Address</th>
                        <th>Class Status</th>
                        <th class="text-center" style="width: 250px;">Enrollment Status & Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% if students %}
                        {% for student in students %}
                        <tr>
                            <td class="fw-bold text-secondary">{{ student.student_id }}</td>
                            <td class="text-dark fw-semibold">{{ student.first_name }} {{ student.last_name }}</td>
                            <td>
                                <!-- Primary Email Display -->
                                <div class="fw-bold text-secondary" style="font-size: 0.95rem;">{{ student.email }}</div>
                                
                                <!-- Student Big Data Morandi Badges (English Only) -->
                                <div class="mt-2 d-flex flex-wrap gap-2">
                                    {% if student.course %}
                                        <span class="badge rounded-pill text-dark px-2 py-1" style="background-color: #e0f2fe; font-size: 0.75rem; font-weight: 500; border: 1px solid #bae6fd;">📘 Course: {{ student.course.name }}</span>
                                        <span class="badge rounded-pill text-dark px-2 py-1" style="background-color: #f1f5f9; font-size: 0.75rem; font-weight: 500; border: 1px solid #e2e8f0;">👨‍🏫 Teacher: {% if student.course.teacher %}{{ student.course.teacher.first_name }}{% else %}Unassigned{% endif %}</span>
                                        <span class="badge rounded-pill text-dark px-2 py-1" style="background-color: #dcfce7; font-size: 0.75rem; font-weight: 500; border: 1px solid #bbf7d0;">💯 Score: {{ student.score|default:"0.0" }} </span>
                                        <span class="badge rounded-pill text-dark px-2 py-1" style="background-color: #fef9c3; font-size: 0.75rem; font-weight: 500; border: 1px solid #fef08a;">⏱️ Attd: {{ student.attendance_rate|default:"100.0" }}%</span>
                                    {% else %}
                                        <span class="badge rounded-pill bg-light text-muted px-2 py-1" style="font-size: 0.75rem; border: 1px solid #e2e8f0;">💨 No Course Selected</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td>
                                {% if student.school_class %}
                                    <span class="badge bg-light text-dark border">{{ student.school_class.name }}</span>
                                {% else %}
                                    <span class="text-muted small italic">Not Placed</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if student.is_active %}
                                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 fw-bold"><i class="fas fa-user-check me-1"></i>Officially Enrolled</span>
                                {% else %}
                                    {% if is_admin_mode %}
                                        <div class="mb-2">
                                            <span class="badge bg-warning bg-opacity-15 text-warning px-2 py-1 fw-bold mb-2"><i class="fas fa-hourglass-half me-1"></i>Pending Admission</span>
                                        </div>
                                        <div class="d-flex justify-content-center gap-2">
                                            <form action="{% url 'office:admin_students' %}" method="POST" style="display:inline;">
                                                {% csrf_token %}
                                                <input type="hidden" name="approve_student_id" value="{{ student.id }}">
                                                <button type="submit" class="btn btn-sm btn-success px-2 fw-semibold"><i class="fas fa-check me-1"></i>Approve</button>
                                            </form>
                                            <form action="{% url 'office:admin_students' %}" method="POST" style="display:inline;" onsubmit="return confirm('Reject permanently?');">
                                                {% csrf_token %}
                                                <input type="hidden" name="reject_student_id" value="{{ student.id }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-2 fw-semibold"><i class="fas fa-ban me-1"></i>Reject</button>
                                            </form>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    {% else %}
                        <tr><td colspan="5" class="text-center py-4 text-muted">No matching student profiles found.</td></tr>
                    {% endif %}
                </tbody>
            </table>
        </div>

        <!-- Verified Pagination Section -->
        {% if students.has_other_pages %}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center mb-0">
                    {% if students.has_previous %}
                        <li class="page-item"><a class="page-link" href="?page={{ students.previous_page_number }}{% if request.GET.keywords %}&keywords={{ request.GET.keywords }}{% endif %}">Previous</a></li>
                    {% else %}
                        <li class="page-item disabled"><span class="page-link">Previous</span></li>
                    {% endif %}
                    
                    {% for i in students.paginator.page_range %}
                        {% if students.number == i %}
                            <li class="page-item active"><span class="page-link" style="background-color: #1e3a8a; border-color: #1e3a8a;">{{ i }}</span></li>
                        {% else %}
                            <li class="page-item"><a class="page-link" href="?page={{ i }}{% if request.GET.keywords %}&keywords={{ request.GET.keywords }}{% endif %}">{{ i }}</a></li>
                        {% endif %}
                    {% endfor %}

                    {% if students.has_next %}
                        <li class="page-item"><a class="page-link" href="?page={{ students.next_page_number }}{% if request.GET.keywords %}&keywords={{ request.GET.keywords }}{% endif %}">Next</a></li>
                    {% else %}
                        <li class="page-item disabled"><span class="page-link">Next</span></li>
                    {% endif %}
                </ul>
            </nav>
        {% endif %}

    </div>
</div>
{% endblock %}
