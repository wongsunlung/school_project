import json
from django.shortcuts import render
from django.http import JsonResponse
from django.views.decorators.csrf import csrf_exempt
from django.core.paginator import Paginator  # 🌟 核心：引進 Django 正規分頁器
from main_base.models import Student, Enrollment, Course  # 🟢 確保有 Enrollment
from django.contrib.auth.decorators import login_required

def teacher_index(request):
    """教師端 Portal 首頁"""
    return render(request, 'teachers/teacher.html')


def attendance_list(request):
    """教師端 - 出勤紀錄（每頁 5 筆 - 🟢 完美融合多對多地基）"""
    student_list = Student.objects.all().order_by('id')
    paginator = Paginator(student_list, 5)  # 🌟 精準鎖定：每頁 5 筆資料
    page_number = request.GET.get('page')
    page_obj = paginator.get_page(page_number)
    
    # 🟢 LUNG 終極防線：強行把中間表的出勤率/狀態掛載到前端舊屬性，防止停權悲劇
    for student in page_obj.object_list:
        try:
            enrollment = Enrollment.objects.filter(student=student).first()
            if enrollment and hasattr(enrollment, 'attendance_rate'):
                student.attendance_rate = enrollment.attendance_rate
            else:
                student.attendance_rate = 100.0
        except:
            student.attendance_rate = 100.0
            
    return render(request, 'teachers/attendance.html', {'page_obj': page_obj})

# -----------------------------------------------------
# 1. 網頁渲染：只顯示「我的學生」與「我的課」
# -----------------------------------------------------
@login_required(login_url='users:login')
def grades_list(request):
    """教師端 - 成績輸入（🌟 權限隔離版：只看自己的學生、自己的課）"""
    teacher_email = request.user.email
    
    # 🌟 修正 1：不要把全校學生列出來！只抓「有修我的課」的學生
    # .distinct() 是為了防止學生修了我兩門課，在列表上出現兩次
    student_list = Student.objects.filter(
        enrollments__course__teacher__email=teacher_email
    ).distinct().order_by('id')

    # 💡 測試防呆機制：如果你用 admin 登入測試，且 admin 不是老師，抓不到資料的話：
    if not student_list.exists():
        fallback_course = Course.objects.exclude(teacher__isnull=True).first()
        if fallback_course:
            teacher_email = fallback_course.teacher.email  # 暫時借用第一個有教課的老師
            student_list = Student.objects.filter(
                enrollments__course__teacher__email=teacher_email
            ).distinct().order_by('id')

    paginator = Paginator(student_list, 5)  
    page_number = request.GET.get('page')
    page_obj = paginator.get_page(page_number)
    
    for student in page_obj.object_list:
        # 🌟 修正 2：絕對隔離！把學生的課展開時，只抓「當前登入老師」教的課！
        student.my_enrollments = Enrollment.objects.filter(
            student=student,
            course__teacher__email=teacher_email  # 👈 權限防護罩：不是我的課直接濾掉
        ).select_related('course')
            
    return render(request, 'teachers/grades.html', {'page_obj': page_obj})


