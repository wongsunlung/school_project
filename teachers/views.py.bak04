# ==========================================================
# 💾 實時儲存 API 補給線：接收前端傳來的真實 ID，100% 寫入主地基
# ==========================================================

@csrf_exempt
def api_update_attendance(request):
    """🟢 點名 API 安全升級：精準寫入中間表，絕不誤封鎖學生帳號！"""
    if request.method == 'POST':
        try:
            data = json.loads(request.body)
            student_id = data.get('id')      
            is_present = data.get('status')  # True (出席) 或 False (缺席)
            
            student = Student.objects.get(id=student_id)
            
            # 🟢 修正：點名狀態改為紀錄在選課中間表 Enrollment
            enrollment = Enrollment.objects.filter(student=student).first()
            if enrollment:
                if hasattr(enrollment, 'attendance_rate'):
                    enrollment.attendance_rate = 100.0 if is_present else 0.0
                enrollment.save()
                print(f"--- [DB ATTENDANCE FIX SAVE] Student: {student.first_name} Attendance updated to {is_present} ---")
                return JsonResponse({'status': 'success'})
                
            return JsonResponse({'status': 'error', 'message': 'No enrollment found.'}, status=404)
        except Exception as e:
            return JsonResponse({'status': 'error', 'message': str(e)}, status=400)
    return JsonResponse({'status': 'invalid_method'}, status=405)

# -----------------------------------------------------
# 2. 存檔 API：防止駭客/網頁錯誤去修改別人的成績
# -----------------------------------------------------
@csrf_exempt
def api_update_score(request):
    """🟢 評分 API：真金白銀精準寫入 (加上老師權限驗證)"""
    if request.method == 'POST':
        try:
            data = json.loads(request.body)
            student_id = data.get('id')      
            score_value = data.get('score')  
            course_id = data.get('course_id')  
            
            if not student_id or score_value is None or not course_id:
                return JsonResponse({'status': 'error', 'message': 'Missing Data.'}, status=400)
                
            student = Student.objects.get(id=student_id)
            
            # 🌟 修正 3：API 防護罩。確保要改的這門課，真的是「現在登入的這個老師」教的
            teacher_email = request.user.email
            
            # 測試防呆：如果網頁沒有 request.user.email，預設放行 (正式上線請拿掉此if)
            if not teacher_email: 
                enrollment = Enrollment.objects.filter(student=student, course_id=course_id).first()
            else:
                enrollment = Enrollment.objects.filter(
                    student=student, 
                    course_id=course_id,
                    course__teacher__email=teacher_email # 👈 鎖定老師
                ).first()
            
            if enrollment:
                enrollment.score = int(score_value)
                enrollment.save()
                print(f"--- [DB FIX SAVE] Student: {student.first_name}, Course: {enrollment.course.name} -> {score_value} pts ---")
                return JsonResponse({'status': 'success'})
            else:
                return JsonResponse({'status': 'error', 'message': 'Enrollment not found or Permission Denied!'}, status=403)
                
        except Exception as e:
            return JsonResponse({'status': 'error', 'message': str(e)}, status=400)
            
    return JsonResponse({'status': 'invalid_method'}, status=405)
